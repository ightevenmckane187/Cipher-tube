{
  "name": "@cipher-tube/sentinel",
  "version": "0.0.0",
  "private": true,
  "description": "Zero-trust security enforcement — OPA policy, Ed25519 identity, audit ledger, SAST gates",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "audit:verify": "node scripts/verify-chain.js"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "node-forge": "^1.3.0",
    "opa-wasm": "^1.9.0",
    "pino": "^9.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
