{
  "name": "@cipher-tube/palette",
  "version": "0.0.0",
  "private": true,
  "description": "UX, accessibility, and interface integrity — WCAG 2.2 AA, design tokens, Storybook",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "a11y:audit": "pa11y-ci",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "lint:css": "stylelint 'src/**/*.css'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@axe-core/react": "^4.9.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.9.0",
    "@playwright/test": "^1.45.0",
    "@storybook/addon-a11y": "^8.2.0",
    "@storybook/react": "^8.2.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "eslint": "^9.0.0",
    "lighthouse": "^12.0.0",
    "pa11y": "^8.0.0",
    "stylelint": "^16.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
